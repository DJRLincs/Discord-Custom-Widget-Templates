{
  "_type": "discord-widget",
  "version": 1,
  "display_name": "Template - Top Hero + Bottom Progress",
  "surfaces": {
    "widget_top": {
      "layout": "widget_top_hero",
      "components": {
        "hero_image": {
          "fields": {
            "image": {
              "presentation_type": "image",
              "value_type": "data",
              "value": "top_image_url"
            }
          }
        },
        "title": {
          "fields": {
            "text": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "top_title"
            }
          }
        },
        "subtitle_1": {
          "fields": {
            "text": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "top_subtitle_1"
            }
          }
        },
        "subtitle_2": {
          "fields": {
            "text": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "top_subtitle_2"
            }
          }
        },
        "subtitle_3": {
          "fields": {
            "text": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "top_subtitle_3"
            }
          }
        }
      }
    },
    "widget_bottom": {
      "layout": "widget_bottom_progress",
      "components": {
        "stat": {
          "fields": {
            "label": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "progress_label"
            },
            "text": {
              "presentation_type": "text",
              "value_type": "data",
              "value": "progress_text"
            },
            "icon": {
              "presentation_type": "image",
              "value_type": "data",
              "value": "progress_icon_url"
            }
          }
        }
      }
    },
    "add_widget_preview": {
      "layout": "add_widget_preview_hero",
      "components": {
        "hero_image": {
          "fields": {
            "image": {
              "presentation_type": "image",
              "value_type": "data",
              "value": "top_image_url"
            }
          }
        }
      }
    }
  }
}
