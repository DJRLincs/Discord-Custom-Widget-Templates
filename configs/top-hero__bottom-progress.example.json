{
  "discord": {
    "app_id": "DISCORD_APP_ID",
    "user_id": "DISCORD_USER_ID",
    "bot_token_env": "DISCORD_BOT_TOKEN",
    "identity_id": 0
  },
  "widget": {
    "display_name": "Top Hero + Bottom Progress",
    "sync_timezone_label": "UTC",
    "dynamic": [
      { "type": 1, "name": "top_title", "value": "My Widget" },
      { "type": 1, "name": "top_subtitle_1", "value": "Subtitle line 1" },
      { "type": 1, "name": "top_subtitle_2", "value": "Subtitle line 2" },
      { "type": 1, "name": "top_subtitle_3", "value": "Subtitle line 3" },
      { "type": 1, "name": "objective_name", "value": "Daily Goal" },
      { "type": 1, "name": "objective_description", "value": "3 of 10 complete" },
      { "type": 2, "name": "progress_current_value", "value": 3 },
      { "type": 2, "name": "progress_max_value", "value": 10 },
      { "type": 3, "name": "top_image_url", "value": { "url": "https://example.com/top.png" } },
      { "type": 3, "name": "objective_image_url", "value": { "url": "https://example.com/icon.png" } }
    ]
  }
}

